# ─── API environment ─────────────────────────────────────────────
# Copy to `.env` for local dev. In production set these in the Render
# dashboard (pdev-api). `.env` is gitignored — never commit real secrets.

# ─── Core ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# Local dev = SQLite. Production = PostgreSQL — the Render build flips the
# Prisma datasource automatically (apps/api/scripts/use-postgres.js), so you
# do NOT change this file for prod; you set DATABASE_URL in Render instead.
DATABASE_URL="file:./dev.db"
# Required in production — own-JWT auth refuses to start without it.
# Render generates this automatically via render.yaml.
JWT_SECRET=

# ─── CORS ────────────────────────────────────────────────────────
# Comma-separated EXACT origins (no wildcard). Unset in dev → localhost
# defaults. Production: your web origin, e.g. https://app.definedbaseball.com
CORS_ORIGINS=

# ─── Storage ─────────────────────────────────────────────────────
# local | s3 | bunny.  Production = bunny.
STORAGE_DRIVER=local

# Bunny Stream (when STORAGE_DRIVER=bunny) — enable "MP4 Fallback" on the
# library so the custom video player gets a progressive MP4.
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOSTNAME=          # pull-zone host, e.g. vz-xxxx-yyy.b-cdn.net
BUNNY_STREAM_MP4_QUALITY=720p

# AWS S3 (only when STORAGE_DRIVER=s3) — legacy/Terraform path. NOTE the code
# reads S3_VIDEO_BUCKET + CDN_BASE_URL (not AWS_S3_BUCKET / CLOUDFRONT_DOMAIN).
AWS_REGION=
S3_VIDEO_BUCKET=
CDN_BASE_URL=

# ─── Production seed (seed.prod.ts) — the 3 Admin coach accounts ──
# connor/jacob/daniel@definedbaseball.com are seeded as ADMIN. Passwords
# default to "PasswordCoach"; override per-account here (or in the host env)
# so the real launch passwords never live in the repo. Rotate at go-live.
SEED_PW_CONNOR=
SEED_PW_JACOB=
SEED_PW_DANIEL=

# ─── Error monitoring (optional) ─────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
