# ─── Database ─────────────────────────────────────────────────
# Dev (SQLite)
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL on RDS)
# DATABASE_URL="postgresql://user:password@host:5432/playerdev?schema=public"

# ─── Auth ─────────────────────────────────────────────────────
# Production: AWS Cognito
# COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# COGNITO_REGION=us-east-1

# ─── AWS S3 (Video Storage) ──────────────────────────────────
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=playerdev-videos
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── AWS CloudFront (Video CDN) ──────────────────────────────
# CLOUDFRONT_DOMAIN=dxxxxxxxxxx.cloudfront.net

# ─── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
