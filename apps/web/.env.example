# ─── Web environment ─────────────────────────────────────────────
# Copy to `.env` for local dev; set in the Render dashboard (pdev-web) for prod.

NODE_ENV=development
PORT=3000

# Where the Next server proxies /api/* to. Dev defaults to localhost:3001.
# Production: the pdev-api public URL, e.g. https://pdev-api-xxxx.onrender.com
API_PROXY_TARGET=http://localhost:3001

# Demo quick-login buttons on /login. Hidden in production builds; set to
# "true" only if you deliberately want them in a non-dev environment.
# NEXT_PUBLIC_ENABLE_DEMO_LOGIN=true

# Error monitoring (optional) — enables the Sentry build integration.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
